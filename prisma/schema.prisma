// Kryptox Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  username          String    @unique
  email             String    @unique
  passwordHash      String
  publicAddress     String    @unique
  avatar            String?
  bio               String?
  isBusiness        Boolean   @default(false)
  isVerified        Boolean   @default(false)
  isPremium         Boolean   @default(false)
  isEmailVerified   Boolean   @default(false)
  emailVerifyCode   String?
  googleId          String?
  phoneNumber       String?
  isPhoneVerified   Boolean   @default(false)
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Demo mode balances (JSON)
  demoBalances      String    @default("{\"USDT\":100,\"ETH\":0.05,\"BTC\":0.001,\"SOL\":2,\"BNB\":0.1,\"USDC\":50,\"TRX\":500,\"TON\":5}")
}

model Message {
  id           String        @id @default(uuid())
  fromUsername String
  toUsername   String
  text         String?
  amount       Float?
  currency     String?
  txHash       String?
  type         MessageType   @default(TEXT)
  status       MessageStatus @default(SENT)
  claimToken   String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Invoice {
  id              String        @id @default(uuid())
  businessUsername String
  amount          Float
  currency        String        @default("USDT")
  description     String
  invoiceNumber   String        @unique
  status          InvoiceStatus @default(PENDING)
  paidByUsername  String?
  paidAt          DateTime?
  txHash          String?
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Auction {
  id             String        @id @default(uuid())
  username       String        @unique
  startingBid    Float
  currentBid     Float
  currentBidder  String?
  bidCount       Int           @default(0)
  winnerUsername String?
  endsAt         DateTime
  status         AuctionStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model ReservedUsername {
  id        String   @id @default(uuid())
  username  String   @unique
  reason    String   @default("system")
  createdAt DateTime @default(now())
}

model PriceCache {
  id        String   @id @default(uuid())
  symbol    String   @unique
  priceUSD  Float
  change24h Float    @default(0)
  updatedAt DateTime @updatedAt
}

enum MessageType {
  TEXT
  PAYMENT
  REQUEST
  RECEIPT
}

enum MessageStatus {
  SENT
  CONFIRMED
  DECLINED
  CLAIMED
}

enum InvoiceStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum AuctionStatus {
  ACTIVE
  ENDED
  RESERVED
}
